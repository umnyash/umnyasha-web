block variables

doctype html
html(lang="ru")
  head
    meta(charset="utf-8")
    title= title
    meta(name="viewport" content="width=device-width, initial-scale=1")
    link(rel="stylesheet" href= pageClass === 'article-page' ? '../../css/style.css' : 'css/style.css')
  body
    include ../components/components
    +page-header
    block content
    +page-footer

extends ../../layout/layout

block variables
  - var title = 'БЭМ'
  - var pageClass = 'article-page'

block content
  main(class= pageClass)
    article.content
      h1 Колбэки
      p #[dfn #[abbr(title='Блок, элемент, модификатор') Колбэк-функция]] – это функция, переданная в другую функцию в качестве аргумента, которая затем вызывается по завершению какого-либо действия.
